# 后端服务配置
PORT=8080
ENVIRONMENT=development

# 区块链配置
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=1

# 智能合约地址
COMPLIANCE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# KYC服务配置
KYC_SERVICE_API_KEY=your_kyc_service_api_key
KYC_SERVICE_ENDPOINT=https://api.kyc-service.com/v1/verify

# 黑名单服务配置
OFAC_API_KEY=your_ofac_api_key
OFAC_API_ENDPOINT=https://api.treasury.gov/ofac

# 身份验证配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=24h

# 数据库配置（如果需要）
DATABASE_URL=postgres://username:password@localhost:5432/rwa_gateway

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id

# 安全配置
HSM_KEY_ID=your_hsm_key_id
MPC_THRESHOLD=3
MPC_TOTAL_SIGNERS=5

# 断路器配置
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_THRESHOLD=5

# 预言机配置
ORACLE_API_KEY=your_oracle_api_key
ORACLE_ENDPOINT=https://api.oracle-service.com/v1/prices
