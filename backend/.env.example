PORT=8081
ENVIRONMENT=development
DATABASE_URL=./rwa_gateway.db
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRATION=24h
ALLOWED_ORIGIN=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120

# Local showcase providers
KYC_MODE=demo
SANCTIONS_MODE=demo

# External KYC provider; required when KYC_MODE is not demo
KYC_SERVICE_API_KEY=
KYC_SERVICE_ENDPOINT=

# Optional on-chain KYC hash anchoring
RPC_URL=
ANCHOR_PRIVATE_KEY=
COMPLIANCE_ENGINE_ADDRESS=
